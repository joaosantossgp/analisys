# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .streamlit/secrets.toml e preencha com suas credenciais.
# O arquivo secrets.toml está no .gitignore — NUNCA commite credenciais.
#
# No Streamlit Community Cloud, configure em:
#   App settings → Secrets → cole o bloco [database] abaixo.
#
# IMPORTANTE: Use a URI do Transaction Pooler (porta 6543), não 5432.
# No painel Supabase: Settings → Database → Connection string → Transaction pooler
# ─────────────────────────────────────────────────────────────────────────────

[database]
url = "postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"
