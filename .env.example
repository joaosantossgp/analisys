# Environment variables for cvm_repots_capture
# Copy to .env and fill in your values (never commit .env)

# PostgreSQL connection string (production)
# If not set, the app falls back to SQLite at data/db/cvm_financials.db
DATABASE_URL=postgresql://user:password@host:5432/cvm_financials

# Optional: override SQLite path (default: data/db/cvm_financials.db)
# SQLITE_PATH=data/db/cvm_financials.db

# Optional: override canonical project directories
# CVM_DATA_DIR=data
# CVM_INPUT_DIR=data/input
# CVM_OUTPUT_DIR=output
# CVM_REPORTS_DIR=output/reports
# CVM_LOG_DIR=output/logs
# CVM_CACHE_DIR=data/cache
# CVM_METADATA_DIR=data/metadata
# CVM_CANONICAL_ACCOUNTS_PATH=data/canonical_accounts.csv

# CVM fetch and retry settings
# CVM_BASE_URL=https://dados.cvm.gov.br/dados/CIA_ABERTA/DOC
# CVM_COMPANY_LIST_TIMEOUT=30
# CVM_DOWNLOAD_TIMEOUT=60
# CVM_MAX_EXCEL_LOCK_RETRIES=10
# CVM_COMPANY_DB_MAX_RETRIES=3
# CVM_COMPANY_DB_RETRY_BACKOFF_SECONDS=1.2

# Updater planner defaults
# UPDATER_SKIP_COMPLETE=1
# UPDATER_FAST_LANE=1
# UPDATER_FORCE_REFRESH=0
